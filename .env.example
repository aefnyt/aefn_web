# ============================================================
# AEFN — Variables de entorno
# ============================================================
# Copia este archivo a .env.local (desarrollo) o configura estas
# variables en el panel de Vercel (producción).
#
# NUNCA subas .env.local a git (ya está en .gitignore).
# ============================================================

# ------------------------------------------------------------
# Base de datos (SQLite local — solo para desarrollo)
# En producción (Vercel) NO se usa Prisma, se usa GitHub API.
# ------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ------------------------------------------------------------
# GitHub — Token de acceso personal (PAT)
# ------------------------------------------------------------
# Necesario para que el panel admin pueda leer/editar los JSON
# del repositorio vía GitHub Contents API.
#
# Cómo crearlo:
# 1. Ve a https://github.com/settings/tokens
# 2. "Generate new token (classic)"
# 3. Marca el scope "repo" (acceso completo a repos privados/públicos)
# 4. Copia el token (empieza con ghp_)
# 5. Pégalo aquí (desarrollo) o en Vercel (producción)
#
# IMPORTANT: Usa un token SOLO para este proyecto.
# Si lo comprometes, revócalo en GitHub inmediatamente.
# ------------------------------------------------------------
GITHUB_TOKEN="dev-placeholder-replace-with-real-token"

# ------------------------------------------------------------
# Claves de acceso al panel admin
# ------------------------------------------------------------
# JSON con las claves para cada módulo. El formato es:
# {"admin":"clave-admin","profesores":"clave-profes","eventos":"...",...}
#
# La clave "admin" da acceso a TODOS los módulos.
# Las demás claves dan acceso SOLO a ese módulo.
#
# CAMBIA estas claves por unas seguras antes de deployar.
# Usa letras, números y símbolos. Mínimo 12 caracteres recomendado.
# ------------------------------------------------------------
ACCESS_KEYS='{"admin":"aefn-admin-2025","profesores":"fisica-profs","eventos":"eventos-ecfn","grupos":"investiga-2025","noticias":"news-aefn","clubes":"clubes-ecfn","galeria":"galeria-aefn"}'
